# Restaurant AI Bot — Environment Variables
# Copy this to .env and fill in your values

# === Telegram ===
TELEGRAM_BOT_TOKEN=

# === Google Places API ===
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=

# === Email (Resend) ===
# Get from https://resend.com/api-keys
RESEND_API_KEY=
# Must be verified in Resend: https://resend.com/domains
FROM_EMAIL=neo@unfilterllc.com

# === SMS (Twilio) ===
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio phone number (e.g. +1234567890)
TWILIO_FROM_NUMBER=

# === Domain ===
# Public URL where the demo server is deployed
DEMO_BASE_URL=https://hirehuman.fyi
# How long demo links stay active (hours)
DEMO_EXPIRE_HOURS=72

# === Telegram Admin ===
# Your Telegram user ID (get from @userinfobot)
ADMIN_USER_IDS=8057854284

# === Scanner ===
# Comma-separated list of areas to scan
SCAN_CITIES=
# Leave empty to use defaults (24 Houston neighborhoods)

# === Railway ===
# Railway token for CLI-less deploys
RAILWAY_API_TOKEN=
